#!/usr/bin/env python3
"""
Repo Clone Tool - Clone and organize git repositories with submodule support.

Usage:
    repo-clone [OPTIONS] <url>        Clone/update a single repository
    repo-clone --watch [OPTIONS]      Monitor clipboard for repo URLs

This script clones repositories organized under:
    $HOME/<hosting_shortcode>/<username>/<repo>

Examples:
    repo-clone git@github.com:user/repo.git
    repo-clone https://github.com/user/repo
    repo-clone https://huggingface.co/TheBloke/model
    repo-clone --shallow https://github.com/user/large-repo
    repo-clone --watch                    # Monitor clipboard
    repo-clone --watch --shallow          # Monitor with shallow clones
    repo-clone --watch --selection both   # Monitor both clipboards (Linux)

Features:
    - Automatic submodule initialization (--recursive by default)
    - Updates existing repos with fetch/pull and submodule sync
    - Fixes repos that were cloned without submodules
    - Special handling for Hugging Face (git lfs)
    - Clipboard watch mode for continuous cloning
"""

from __future__ import annotations

# =============================================================================
# Architecture note — for code readers
# =============================================================================
#
# What this script does, plainly:
#   repo-clone takes a git URL, figures out where the repo should live on disk
#   ($HOME/$host/$org/$repo, always), and either clones it fresh or updates it
#   if it already exists. With --fork, it first creates a GitHub fork (or
#   verifies one already exists), then clones both the source and the fork —
#   two real directories, each with the correct `origin` remote, and the fork
#   side gets an `upstream` remote pointing back at the source. With --watch,
#   it monitors the clipboard and clones anything that looks like a repo URL.
#
# The shape of this file as a journey:
#   We start with the logging primitives (log_info, log_warn, log_error, log_debug)
#   because everything that follows needs to emit output. On top of those we build
#   the structured emit() layer — one function that handles both human-readable
#   stderr lines and machine-parseable JSONL on stdout, so the --fork path can
#   produce events that scripts can consume.
#
#   With output settled, we lay down the --fork-specific code: gh preflight,
#   fork identity resolution, idempotent fork creation, fork-side clone with
#   retry, upstream remote wiring, and repo_clone_fork() which orchestrates them
#   all. These sections are new as of 2026-05-06 and represent most of the
#   recent growth in the file.
#
#   The key seam: after repo_clone_fork() ends, the file transitions into the
#   existing infrastructure that the fork code was built on top of — the
#   dataclasses (RepoInfo, CloneOptions, WatchConfig, ForkOptions), URL parsing,
#   config loading, watch mode, git execution helpers, clone_repo, and the
#   original repo_clone orchestrator. That seam is marked explicitly below
#   around line 770. If you're reading the new fork code and see a type you
#   haven't found yet — RepoInfo, CloneOptions, ForkOptions — they live in the
#   dataclasses block just past that seam.
#
#   At the end: agent help (_AGENT_HELP_SECTIONS / render_agent_help) followed
#   by main(), which parses arguments, merges env + config + CLI, and dispatches
#   to one of the three orchestrators: watch_clipboard, repo_clone_fork, or
#   repo_clone.
#
# Major subsystems in file order:
#  1. Logging primitives          — log_info / log_warn / log_error / log_debug
#  2. Output / structured logging — emit(), set_output_mode(), two-mode design
#  3. gh preflight                — verify gh present and authed before fork work
#  4. Fork identity resolution    — compute (target_org, fork_name, clone_url)
#  5. Fork creation (idempotent)  — probe-then-create via gh api + gh repo fork
#  6. Fork-side clone & upstream  — clone with retry, wire upstream remote
#  7. Orchestrator: repo_clone_fork — stitches steps 3-6 together
#  --- seam: new --fork code above / existing infrastructure below ---
#  8. Dataclasses                 — RepoInfo, CloneOptions, WatchConfig, ForkOptions
#  9. URL parsing helpers         — parse_git_url, normalize_clone_url
# 10. Config file loading         — load_config + parse_yaml_subset (stdlib fallback)
# 11. Watch mode                  — detect_clipboard_backend, watch_clipboard
# 12. Git execution helpers       — run_git, check_local_changes, update_repo
# 13. Clone / update primitives   — clone_repo
# 14. Top-level entry points      — repo_clone (non-fork path)
# 15. Agent help                  — _AGENT_HELP_SECTIONS dict + render_agent_help
# 16. main()                      — argument parsing, env/config/CLI precedence, dispatch
#
# Design decisions worth knowing up front:
#
#   Stdlib only: no third-party runtime dependencies (pyyaml is optional; we fall
#   back to parse_yaml_subset). The rationale is portability — any Python 3.9+
#   install can run this without pip.
#   See docs/design/repo-clone-DESIGN-stdlib-portability.md.
#
#   Two output modes: "human" (prefixed lines on stderr) and "jsonl" (compact
#   JSON on stdout). Humans need scannable INFO:/WARN:/ERROR: prefixes;
#   programmatic consumers need structured events they can parse reliably.
#   A single emit() call serves both paths.
#   See docs/design/repo-clone-DESIGN-jsonl-output.md.
#
#   Why shell out to gh: GitHub's auth flow (OAuth, SSH, OIDC, fine-grained PATs)
#   is complex to implement correctly. gh already handles it. We lean on
#   `gh api` and `gh repo fork` rather than re-implementing the wheel.
#
#   Why two clones for --fork: we clone BOTH the source and the fork. This
#   preserves the "path tells you origin" invariant — gh/acme/widget and
#   gh/myfork/widget are unambiguously distinct directories, each with the
#   correct remote (origin vs upstream). Merging them would require naming
#   conventions or symlinks; two directories keeps the model simple.
#
# For the "why" behind individual choices, see
# docs/design/repo-clone-MAINTAINERS-decisions.md (dated decision log).
# For schemas and contracts, see docs/design/.
# =============================================================================

import sys
import subprocess
import argparse
import os
import re
import time
import shutil
import signal
from pathlib import Path
from urllib.parse import urlparse
from dataclasses import dataclass, field
from typing import Optional, List, Tuple
